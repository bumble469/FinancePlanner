generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////
// ENUMS
//////////////////////

enum AccountType {
  INDIVIDUAL
  COMPANY
  CLUB
}

enum WorkItemType {
  PROJECT
  EVENT
  PLAN
}

enum WorkItemStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
  CANCELLED
}

enum ExpenseCategory {
  SALARY
  MARKETING
  TOOLS
  OPERATIONS
  EVENT
  OTHER
}

enum MemberRole {
  ADMIN    // creator, full access
  MANAGER  // can manage their department, view others
  MEMBER   // can only log expenses in assigned department
}

enum IncomeType {
  INVESTMENT
  REVENUE
}

//////////////////////
// AUTH / IDENTITY (unchanged)
//////////////////////

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  password      String?
  emailVerified DateTime?
  image         String?
  role          String    @default("user")

  account             Account?
  oauthAccount        OAuthAccount?
  refreshTokens       RefreshToken[]
  workItemMemberships WorkItemMember[]
  departmentMembers   DepartmentMember[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model OAuthAccount {
  id                String  @id @default(cuid())
  userId            String  @unique
  provider          String
  providerAccountId String
  access_token      String?
  refresh_token     String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("oauth_accounts")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  revokedAt DateTime?
  expiresAt DateTime
  userAgent String?
  ipAddress String?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

//////////////////////
// ACCOUNT (WORKSPACE)
//////////////////////

model Account {
  id   String      @id @default(uuid())
  userId String    @unique
  name   String
  type   AccountType

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workItems WorkItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("accounts")
}

//////////////////////
// WORK ITEM (PROJECT / EVENT / PLAN)
//////////////////////

model WorkItem {
  id        String         @id @default(uuid())
  accountId String
  name      String
  type      WorkItemType
  status    WorkItemStatus @default(ACTIVE)
  budget    Decimal?       @db.Decimal(12, 2) // overall budget set at creation
  currency  String         @default("USD")
  description String?

  account     Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  // type-specific details
  project  Project?
  event    Event?
  planInfo PlanInfo?

  // collaboration
  members     WorkItemMember[]

  // departments and phases
  departments Department[]
  phases      Phase[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("work_items")
}

//////////////////////
// COLLABORATION
//////////////////////

model WorkItemMember {
  id         String     @id @default(uuid())
  workItemId String
  userId     String
  role       MemberRole @default(MEMBER)

  workItem WorkItem @relation(fields: [workItemId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  departmentMembers DepartmentMember[]

  joinedAt DateTime @default(now())

  @@unique([workItemId, userId]) // user can't be added twice to same work item
  @@map("work_item_members")
}

//////////////////////
// DEPARTMENTS (formerly Role)
//////////////////////

model Department {
  id         String   @id @default(uuid())
  workItemId String
  name       String
  budget     Decimal? @db.Decimal(12, 2) // allocated slice of WorkItem budget

  workItem WorkItem @relation(fields: [workItemId], references: [id], onDelete: Cascade)
  members  DepartmentMember[]
  expenses Expense[]

  @@unique([workItemId, name]) // no duplicate department names per work item
  @@map("departments")
}

// which member is assigned to which department
model DepartmentMember {
  id             String @id @default(uuid())
  departmentId   String
  userId         String
  workItemMemberId String

  department     Department     @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  workItemMember WorkItemMember @relation(fields: [workItemMemberId], references: [id], onDelete: Cascade)

  @@unique([departmentId, userId])
  @@map("department_members")
}

//////////////////////
// SPECIALIZED WORK ITEM TYPES
//////////////////////

model Project {
  workItemId   String    @id
  deadline     DateTime?
  methodology  String?

  workItem WorkItem @relation(fields: [workItemId], references: [id], onDelete: Cascade)

  @@map("projects")
}

model Event {
  workItemId     String @id
  venue          String?
  expectedCrowd  Int?
  eventDate      DateTime?

  workItem WorkItem @relation(fields: [workItemId], references: [id], onDelete: Cascade)

  @@map("events")
}

model PlanInfo {
  workItemId String @id
  notes      String?

  workItem WorkItem @relation(fields: [workItemId], references: [id], onDelete: Cascade)

  @@map("plan_info")
}

//////////////////////
// PHASES (formerly Module)
//////////////////////

model Phase {
  id         String @id @default(uuid())
  workItemId String
  name       String
  startDate  DateTime?
  endDate    DateTime?

  workItem WorkItem @relation(fields: [workItemId], references: [id], onDelete: Cascade)

  expenses Expense[]
  income   Income[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("phases")
}

//////////////////////
// FINANCIALS
//////////////////////

// merged Investment + Revenue into a single Income model
model Income {
  id          String     @id @default(uuid())
  phaseId     String
  type        IncomeType // INVESTMENT or REVENUE
  amount      Decimal    @db.Decimal(12, 2)
  description String?
  receivedAt  DateTime   @default(now())

  phase Phase @relation(fields: [phaseId], references: [id], onDelete: Cascade)

  @@map("income")
}

model Expense {
  id           String          @id @default(uuid())
  category     ExpenseCategory
  description  String?
  amount       Decimal         @db.Decimal(12, 2)
  occurredAt   DateTime        @default(now())

  phaseId      String
  phase        Phase           @relation(fields: [phaseId], references: [id], onDelete: Cascade)

  departmentId String?
  department   Department?     @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  loggedById   String?         // which user logged this expense
  
  createdAt    DateTime        @default(now())

  @@map("expenses")
}